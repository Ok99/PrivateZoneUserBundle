{# @var \Ok99\PrivateZoneCore\UserBundle\Entity\User user #}
<table cellpadding="0" cellspacing="0"
	   style="border-collapse: collapse; margin: 0 auto; border: 0; min-width: 520px; width: 520px;"
	   xmlns="http://www.w3.org/1999/html">
	<tr>
		<td>
			{{ 'resetting.email.message'|trans({}, 'FOSUserBundle')|nl2br|replace({
				'%name%': '<strong>' ~ user.name ~ '</strong>',
				'%regnum%': '<strong>' ~ user.fullRegnum ~ '</strong>',
				'%confirmationUrl%': '<a href="' ~ confirmationUrl ~ '" target="_blank">' ~ confirmationUrl ~ '</a>'
			})|raw }}
		</td>
	</tr>
	<tr>
		<td>&nbsp;</td>
	</tr>
</table>